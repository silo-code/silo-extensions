{
  "name": "@silo-extensions/docs-panel",
  "displayName": "Documents Side Panel",
  "version": "0.1.3",
  "description": "Browse and preview markdown documentation from configurable folder roots.",
  "type": "module",
  "files": [
    "dist/",
    "build.mjs"
  ],
  "silo": {
    "id": "silo.docs-panel",
    "engine": "^0.21.0",
    "main": "dist/index.js",
    "publisher": "Silo",
    "permissions": [
      "fs:read"
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "build:watch": "node --watch build.mjs"
  },
  "devDependencies": {
    "@silo-code/sdk": "^0.21.0",
    "@phosphor-icons/react": "^2.1.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0"
  }
}